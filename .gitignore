# secrets
.env
.vault-pass
*.vault-pass

# runtime state (generated by deploy)
server/runtime/
logs/

# legacy / transitional
data/

# ansible
*.retry
ansible/inventory/prod.ini
ansible/inventory/dev.ini
ansible/inventory/*.local.*
# Real vault files (live beside vault.yml.example, or under host_vars/ for
# the Azure throwaway flow). Should be ansible-vault encrypted, but
# gitignored as defense-in-depth in case encryption is skipped. Per-host
# dirs for throwaway VMs have timestamped RG names — no point tracking them.
ansible/group_vars/*/vault.yml
ansible/host_vars/

# azure-validation helpers: throwaway secrets + generated client configs
.secrets/
out/

# test fixtures (local-only)
test/ssh/id_ed25519
test/ssh/id_ed25519.pub
test/ssh/known_hosts

# editor / OS
.DS_Store
.idea/
.vscode/
